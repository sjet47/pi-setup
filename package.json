{
  "name": "pi-setup",
  "version": "0.1.0",
  "type": "module",
  "description": "Personal Pi extension collection — a single source for all my custom plugins.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:cache-graph": "tsc --noEmit -p extensions/pi-cache-graph/tsconfig.json",
    "test": "npm run test:wakatime && npm run test:cache-graph",
    "test:wakatime": "node --import tsx --test extensions/pi-wakatime/test/*.test.ts",
    "test:cache-graph": "vitest run --config extensions/pi-cache-graph/vitest.config.ts"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-shots/index.ts",
      "./extensions/pi-stats/src/index.ts",
      "./extensions/pi-execution-time/execution-time.ts",
      "./extensions/pi-intercom/index.ts",
      "./extensions/pi-fast-mode/index.ts",
      "./extensions/pi-search-prompts/index.ts",
      "./extensions/pi-inline-skill/index.ts",
      "./extensions/pi-wakatime/src/index.ts",
      "./extensions/pi-cache-graph/index.ts"
    ],
    "skills": [
      "./extensions/pi-intercom/skills"
    ]
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "sql.js": "^1.11.0",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@earendil-works/pi-tui": "^0.80.7",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.13.10",
    "tsx": "^4.23.1",
    "typescript": "^5.8.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  }
}
